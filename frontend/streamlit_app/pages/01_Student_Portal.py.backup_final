                color = "#856404"
            else:
                bg = "#d1ecf1"
                border = "#17a2b8"
                color = "#0c5460"
            
            opacity = "1" if not notif['read'] else "0.7"
            
            st.markdown(f"""
            <div style="background: {bg}; border-left: 5px solid {border}; 
                       border-radius: 10px; padding: 20px; margin: 10px 0; opacity: {opacity};">
                <div style="display: flex; justify-content: space-between; align-items: center;">
                    <div>
                        <span style="font-size: 1.2em; margin-right: 10px;">{notif['icon']}</span>
                        <strong style="color: {color};">{notif['title']}</strong>
                    </div>
                    <span style="color: {color}; font-size: 0.9em;">{notif['time']}</span>
                </div>
                <p style="color: {color}; margin-top: 10px; margin-left: 30px;">{notif['message']}</p>
            </div>
            """, unsafe_allow_html=True)
    
