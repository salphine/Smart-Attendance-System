        with col2:
            st.markdown("""
            <div class="dashboard-card">
                <div class="stat-circle"></div>
                <h3 style="text-align: center;">Classes</h3>
                <p style="text-align: center; font-size: 2em; font-weight: 700; color: #48bb78;">42/48</p>
            </div>
            """, unsafe_allow_html=True)
        
        with col3:
            st.markdown("""
            <div class="dashboard-card">
                <div class="stat-circle"></div>
                <h3 style="text-align: center;">Rank</h3>
                <p style="text-align: center; font-size: 2em; font-weight: 700; color: #fbbf24;">#15</p>
            </div>
            """, unsafe_allow_html=True)
        
        with col4:
