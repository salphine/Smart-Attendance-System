                st.markdown("####  Student Login")
                
                reg_number = st.text_input("Registration Number", placeholder="E35/1234/2020")
                password = st.text_input("Password", type="password", placeholder="Enter your password")
                
                col1, col2 = st.columns(2)
                with col1:
                    remember = st.checkbox("Remember me")
                with col2:
                    st.markdown("[Forgot Password?](#)")
                
                submitted = st.form_submit_button("Login to Portal", width='stretch')
                
                if submitted:
                    if reg_number and password:
                        # Demo login - accept any credentials
                        st.session_state.student_logged_in = True
                        st.session_state.student_info = {
                            'reg_number': reg_number,
                            'name': 'John Kamau',
                            'course': 'Computer Science',
                            'year': 3,
                            'email': f'{reg_number}@students.embu.ac.ke'
                        }
                        st.session_state.current_step = 'dashboard'
                        st.rerun()
                    else:
                        st.error("Please enter both Registration Number and Password")
        
        else:  # Register
            with st.form("register_form"):
                st.markdown("####  Student Registration")
                
                col1, col2 = st.columns(2)
                with col1:
                    full_name = st.text_input("Full Name", placeholder="John Kamau")
                    reg_number = st.text_input("Registration Number", placeholder="E35/1234/2020")
                    email = st.text_input("Email", placeholder="john@students.embu.ac.ke")
                
                with col2:
                    course = st.selectbox("Course", [
                        "Computer Science",
                        "Business IT",
                        "Engineering",
                        "Medicine",
                        "Education",
                        "Law"
                    ])
                    year = st.selectbox("Year of Study", [1, 2, 3, 4, 5, 6])
                    phone = st.text_input("Phone Number", placeholder="0712345678")
                
                password = st.text_input("Password", type="password")
                confirm_password = st.text_input("Confirm Password", type="password")
                
                terms = st.checkbox("I agree to the Terms and Conditions")
                
                submitted = st.form_submit_button("Register & Continue", width='stretch')
                
                if submitted:
                    if full_name and reg_number and email and password:
                        if password == confirm_password:
                            if terms:
                                st.session_state.student_logged_in = True
                                st.session_state.student_info = {
                                    'reg_number': reg_number,
                                    'name': full_name,
                                    'course': course,
                                    'year': year,
                                    'email': email,
                                    'phone': phone
                                }
                                st.session_state.current_step = 'face_registration'
                                st.success("Registration successful! Please register your face.")
                                time.sleep(2)
                                st.rerun()
                            else:
                                st.error("Please accept Terms and Conditions")
                        else:
                            st.error("Passwords do not match")
                    else:
                        st.error("Please fill all required fields")

