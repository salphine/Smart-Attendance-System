    elif st.session_state.current_step == 'mark_attendance':
        st.markdown("""
        <div style="background: white; border-radius: 20px; padding: 25px; margin-bottom: 20px;">
            <h2> Mark Attendance</h2>
            <p style="color: #666;">Face verification with advanced anti-spoofing</p>
        </div>
        """, unsafe_allow_html=True)
        
        col1, col2 = st.columns([3, 2])
        
        with col1:
            st.markdown('<div class="camera-container">', unsafe_allow_html=True)
            
            # Camera input
            img_file = st.camera_input("Position your face within the guide", key="attendance_camera")
            
            if img_file:
                st.session_state.captured_images.append(img_file)
                
                # Simulate face detection
                with st.spinner("Analyzing face..."):
                    progress = st.progress(0)
                    for i in range(100):
                        progress.progress(i + 1)
                        time.sleep(0.02)
                    
                    st.success(" Face detected successfully!")
                    
                    # Start liveness check
                    if st.button("Start Liveness Verification", width='stretch'):
                        st.session_state.current_step = 'liveness_check'
                        st.rerun()
            
            st.markdown('<div class="camera-overlay"></div>', unsafe_allow_html=True)
            st.markdown('<div class="face-guide"></div>', unsafe_allow_html=True)
            st.markdown('</div>', unsafe_allow_html=True)
        
        with col2:
            st.markdown("""
            <div style="background: white; border-radius: 20px; padding: 25px;">
                <h4> Instructions</h4>
                <ul style="list-style-type: none; padding: 0;">
