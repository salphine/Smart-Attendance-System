        # Recent Activity
        st.markdown('<div class="dashboard-card">', unsafe_allow_html=True)
        st.markdown("####  Recent Activity")
        
        activities = [
            ("Today 08:30 AM", " Attendance marked - CS301", "success"),
            ("Yesterday 10:00 AM", " Liveness verified - CS401", "success"),
            ("Yesterday 02:15 PM", " Attendance marked - CS202", "success"),
