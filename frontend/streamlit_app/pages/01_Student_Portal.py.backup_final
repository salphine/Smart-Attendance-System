                        </div>
                    </div>
                </div>
            </div>
            """, unsafe_allow_html=True)
    
    elif st.session_state.current_step == 'liveness_check':
        st.markdown("""
        <div style="background: white; border-radius: 20px; padding: 25px; margin-bottom: 20px;">
            <h2> Liveness Verification</h2>
            <p style="color: #666;">Advanced anti-spoofing detection in progress</p>
        </div>
        """, unsafe_allow_html=True)
        
        col1, col2 = st.columns([2, 1])
        
        with col1:
            st.markdown('<div class="dashboard-card">', unsafe_allow_html=True)
            
            # Liveness checks
            checks = [
                " Blink Detection",
                " 3D Face Analysis",
                " Screen/Photo Detection",
                " Head Movement",
                " Texture Analysis",
                " Micro-expression Analysis"
            ]
            
            results = []
            progress_bar = st.progress(0)
            status_text = st.empty()
            
            for i, check in enumerate(checks):
                status_text.text(f"Checking: {check}")
                progress_bar.progress((i + 1) * 16)
                
                # Simulate processing
                time.sleep(1)
                
                # Random result (in real system, this would be actual ML)
                score = random.uniform(0.85, 0.99)
                results.append(score)
                
                if score > 0.9:
                    st.markdown(f"<span class='badge badge-success'> {check}: Passed ({score:.1%})</span>", unsafe_allow_html=True)
                elif score > 0.7:
                    st.markdown(f"<span class='badge badge-warning'> {check}: Acceptable ({score:.1%})</span>", unsafe_allow_html=True)
                else:
                    st.markdown(f"<span class='badge badge-danger'> {check}: Failed ({score:.1%})</span>", unsafe_allow_html=True)
            
            # Calculate overall score
            overall_score = np.mean(results)
            st.session_state.liveness_score = overall_score
            
            status_text.text("Verification Complete!")
            progress_bar.progress(100)
            
            st.markdown('</div>', unsafe_allow_html=True)
        
        with col2:
            st.markdown('<div class="dashboard-card">', unsafe_allow_html=True)
            
            # Gauge chart
            fig = go.Figure(go.Indicator(
                mode="gauge+number",
                value=overall_score * 100,
                domain={'x': [0, 1], 'y': [0, 1]},
                title={'text': "Liveness Score"},
                gauge={
                    'axis': {'range': [None, 100]},
                    'bar': {'color': "#667eea"},
                    'steps': [
                        {'range': [0, 50], 'color': "#f8d7da"},
                        {'range': [50, 75], 'color': "#fff3cd"},
                        {'range': [75, 100], 'color': "#d4edda"}
                    ],
                    'threshold': {
                        'line': {'color': "red", 'width': 4},
                        'threshold': 85
                    }
                }
            ))
            fig.update_layout(height=300)
            st.plotly_chart(fig, width='stretch')
            
            # Result
            if overall_score > 0.85:
                st.markdown("""
                <div style="text-align: center; margin-top: 20px;">
                    <div class="success-checkmark">
                        <div class="check-icon"></div>
                    </div>
                    <h3 style="color: #28a745;">Liveness Verified!</h3>
                    <p>Anti-spoofing check passed</p>
                </div>
                """, unsafe_allow_html=True)
                
                if st.button(" Mark Attendance", width='stretch'):
                    st.balloons()
                    st.success("Attendance marked successfully!")
                    
                    # Add to history
                    st.session_state.attendance_history.append({
                        'date': datetime.now().strftime('%Y-%m-%d'),
                        'time': datetime.now().strftime('%H:%M:%S'),
                        'course': 'CS301',
                        'status': 'Present',
                        'confidence': f"{overall_score:.1%}"
                    })
                    
                    time.sleep(2)
                    st.session_state.current_step = 'dashboard'
                    st.rerun()
            else:
                st.markdown(f"""
                <div style="text-align: center; margin-top: 20px;">
                    <h3 style="color: #dc3545;">Verification Failed</h3>
                    <p>Confidence too low: {overall_score:.1%}</p>
                </div>
                """, unsafe_allow_html=True)
                
                if st.button(" Try Again", width='stretch'):
                    st.session_state.current_step = 'mark_attendance'
                    st.rerun()
            
            st.markdown('</div>', unsafe_allow_html=True)
    
    elif st.session_state.current_step == 'my_records':
        st.markdown("""
        <div style="background: white; border-radius: 20px; padding: 25px; margin-bottom: 20px;">
            <h2> My Attendance Records</h2>
            <p style="color: #666;">View your complete attendance history</p>
        </div>
        """, unsafe_allow_html=True)
        
        # Filters
        col1, col2, col3 = st.columns(3)
        with col1:
            month = st.selectbox("Month", ["January", "February", "March", "April", "May", "June"])
        with col2:
            course = st.selectbox("Course", ["All", "CS301", "CS401", "CS202", "CS305"])
        with col3:
            status = st.selectbox("Status", ["All", "Present", "Absent"])
        
        # Summary stats
        col1, col2, col3, col4 = st.columns(4)
        with col1:
            st.metric("Total Classes", "48")
        with col2:
            st.metric("Present", "42")
        with col3:
            st.metric("Absent", "6")
        with col4:
            st.metric("Attendance Rate", "87.5%")
        
        # Generate sample records
        records = []
        courses = ['CS301', 'CS401', 'CS202', 'CS305']
        statuses = ['Present', 'Present', 'Present', 'Present', 'Present', 'Absent']
        
        for i in range(30):
            date = (datetime.now() - timedelta(days=i)).strftime('%Y-%m-%d')
            records.append({
                'Date': date,
                'Course': random.choice(courses),
                'Time': f"{random.randint(8, 16):02d}:{random.randint(0, 59):02d}",
                'Status': random.choice(statuses),
                'Confidence': f"{random.randint(92, 99)}%"
            })
        
        df = pd.DataFrame(records)
        st.dataframe(
            df,
            width='stretch',
            hide_index=True,
            column_config={
                'Status': st.column_config.Column(
                    "Status",
                    help="Attendance status",
                    width="small"
                ),
                'Confidence': st.column_config.ProgressColumn(
                    "Confidence",
                    help="Verification confidence",
                    min_value=0,
                    max_value=100,
                    format="%s"
                )
            }
        )
        
        # Export options
        col1, col2 = st.columns(2)
        with col1:
            if st.button(" Export as CSV", width='stretch'):
                st.success("Records exported successfully!")
        with col2:
            if st.button(" Print Report", width='stretch'):
                st.info("Preparing report for printing...")
    
    elif st.session_state.current_step == 'face_registration':
        st.markdown("""
        <div style="background: white; border-radius: 20px; padding: 25px; margin-bottom: 20px;">
            <h2> Face Registration</h2>
            <p style="color: #666;">Register your face for future attendance marking</p>
        </div>
        """, unsafe_allow_html=True)
        
        col1, col2 = st.columns(2)
        
        with col1:
            st.markdown('<div class="camera-container">', unsafe_allow_html=True)
            
            # Multiple angle captures
            st.markdown("####  Capture from different angles")
            
            angles = ["Front", "Left", "Right", "Up", "Down"]
            captured = []
            
            for angle in angles:
                st.markdown(f"**{angle} Angle**")
                img = st.camera_input(f"Take {angle} photo", key=f"angle_{angle}")
                if img:
                    captured.append(img)
                    st.success(f" {angle} angle captured")
            
            if len(captured) >= 3:
                if st.button("Complete Registration", width='stretch'):
                    with st.spinner("Processing face data..."):
                        time.sleep(3)
                        st.session_state.face_registered = True
                        st.balloons()
                        st.success(" Face registered successfully!")
                        time.sleep(2)
                        st.session_state.current_step = 'dashboard'
                        st.rerun()
            
            st.markdown('</div>', unsafe_allow_html=True)
        
        with col2:
            st.markdown("""
            <div style="background: white; border-radius: 20px; padding: 25px;">
                <h4> Registration Guidelines</h4>
                <ul style="list-style-type: none; padding: 0;">
                    <li style="margin: 15px 0;"> Capture from 5 different angles</li>
                    <li style="margin: 15px 0;"> Ensure consistent lighting</li>
                    <li style="margin: 15px 0;"> Remove accessories if possible</li>
                    <li style="margin: 15px 0;"> Maintain neutral expression</li>
                    <li style="margin: 15px 0;"> Avoid background distractions</li>
                </ul>
                
                <div style="background: #f8f9fa; border-radius: 15px; padding: 20px; margin-top: 20px;">
                    <h4> Registration Progress</h4>
                    <div class="progress-card">
                        <div class="progress-label">
                            <span>Images Captured</span>
                            <span>{len(captured if 'captured' in locals() else [])}/5</span>
                        </div>
                        <div class="progress-bar-bg">
                            <div class="progress-bar-fill" style="width: {len(captured if 'captured' in locals() else [])*20}%;"></div>
                        </div>
                    </div>
                </div>
            </div>
            """, unsafe_allow_html=True)
    
    elif st.session_state.current_step == 'notifications':
        st.markdown("""
        <div style="background: white; border-radius: 20px; padding: 25px; margin-bottom: 20px;">
            <h2> Notifications</h2>
