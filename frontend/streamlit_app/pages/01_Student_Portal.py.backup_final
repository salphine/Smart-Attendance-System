            <div class="dashboard-card">
                <div class="stat-circle"></div>
                <h3 style="text-align: center;">Week</h3>
                <p style="text-align: center; font-size: 2em; font-weight: 700; color: #f56565;">12</p>
            </div>
            """, unsafe_allow_html=True)
        
        # Charts
