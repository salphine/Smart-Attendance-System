        # Sample notifications
        notifications = [
            {
                'type': 'success',
                'icon': '',
                'title': 'Attendance Marked',
                'message': 'Your attendance for CS301 has been marked successfully.',
                'time': '5 minutes ago',
                'read': False
            },
            {
                'type': 'warning',
                'icon': '',
                'title': 'Low Attendance Alert',
                'message': 'Your attendance in CS401 is below 75%. Please attend next class.',
                'time': '2 hours ago',
                'read': False
            },
            {
                'type': 'info',
                'icon': '?',
                'title': 'Face Registration Reminder',
                'message': 'Update your face data for better recognition accuracy.',
                'time': '1 day ago',
                'read': True
            },
            {
                'type': 'success',
                'icon': '',
                'title': 'Achievement Unlocked',
                'message': 'Perfect attendance for 2 weeks! Keep it up!',
                'time': '3 days ago',
                'read': True
            }
        ]
        
        for notif in notifications:
            if notif['type'] == 'success':
                bg = "#d4edda"
                border = "#28a745"
