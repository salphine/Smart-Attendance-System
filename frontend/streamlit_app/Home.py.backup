    </div>
    """, unsafe_allow_html=True)

with col4:
    st.markdown(f"""
    <div class="metric-card" style="border-bottom-color: #f56565;">
        <div class="metric-label">VERIFICATION RATE</div>
        <div class="metric-value">{st.session_state.analytics_data['verification_success']}%</div>
        <div class="metric-change positive-change">99.9% anti-spoofing</div>
    </div>
    """, unsafe_allow_html=True)

# Analytics Charts Row
col1, col2 = st.columns(2)

with col1:
    st.markdown('<div class="chart-container">', unsafe_allow_html=True)
    st.markdown('<div class="chart-title"> 30-Day Attendance Trend</div>', unsafe_allow_html=True)
    
    # Create attendance trend chart
    fig_trend = go.Figure()
    
    fig_trend.add_trace(go.Scatter(
        x=st.session_state.attendance_trends['dates'][-15:],  # Last 15 days
        y=st.session_state.attendance_trends['values'][-15:],
        mode='lines+markers',
        name='Daily Attendance',
        line=dict(color='#667eea', width=3),
        fill='tozeroy',
        fillcolor='rgba(102, 126, 234, 0.1)'
    ))
    
    # Add average line
    avg_value = np.mean(st.session_state.attendance_trends['values'])
    fig_trend.add_hline(
        y=avg_value,
        line_dash="dash",
        line_color="#48bb78",
        annotation_text=f"Average: {avg_value:.0f}",
        annotation_position="bottom right"
    )
    
    fig_trend.update_layout(
        xaxis_title="Date",
        yaxis_title="Number of Students",
        hovermode='x unified',
        showlegend=False,
        height=350,
        margin=dict(l=40, r=40, t=20, b=40)
    )
    
    st.plotly_chart(fig_trend, use_container_width=True)
    st.markdown('</div>', unsafe_allow_html=True)

with col2:
    st.markdown('<div class="chart-container">', unsafe_allow_html=True)
    st.markdown('<div class="chart-title"> Course Performance</div>', unsafe_allow_html=True)
    
    # Create course performance chart
    fig_courses = go.Figure()
    
    fig_courses.add_trace(go.Bar(
        x=st.session_state.course_performance['courses'],
        y=st.session_state.course_performance['attendance'],
        name='Attendance %',
        marker_color='#667eea',
        text=[f"{v}%" for v in st.session_state.course_performance['attendance']],
        textposition='outside',
        yaxis='y'
    ))
    
    fig_courses.add_trace(go.Scatter(
        x=st.session_state.course_performance['courses'],
        y=st.session_state.course_performance['students'],
        name='Students',
        mode='lines+markers',
        line=dict(color='#48bb78', width=3),
        yaxis='y2'
    ))
    
    fig_courses.update_layout(
        xaxis_title="Course",
        yaxis=dict(title="Attendance %", range=[0, 100]),
        yaxis2=dict(title="Number of Students", overlaying='y', side='right'),
        hovermode='x unified',
        height=350,
        margin=dict(l=40, r=40, t=20, b=40),
        legend=dict(orientation="h", yanchor="bottom", y=1.02, xanchor="right", x=1)
    )
    
    st.plotly_chart(fig_courses, use_container_width=True)
    st.markdown('</div>', unsafe_allow_html=True)

# System Health and Live Activity
col1, col2 = st.columns([3, 2])

with col1:
    st.markdown('<div class="chart-container">', unsafe_allow_html=True)
    st.markdown('<div class="chart-title"> System Health Metrics</div>', unsafe_allow_html=True)
    
    # Create health metrics columns
    health_cols = st.columns(3)
    
    metrics = [
        ("Face Recognition", st.session_state.system_health['face_recognition'], "success"),
        ("Liveness Detection", st.session_state.system_health['liveness_detection'], "warning"),
        ("Anti-Spoofing", st.session_state.system_health['anti_spoofing'], "success"),
        ("Response Time", f"{st.session_state.system_health['response_time']*1000:.0f}ms", "info"),
        ("Active Cameras", st.session_state.system_health['active_cameras'], "info"),
        ("Queue Size", st.session_state.system_health['queue_size'], "warning")
    ]
    
    for i, (label, value, status) in enumerate(metrics):
        with health_cols[i % 3]:
            if status == "success":
                bg_color = "#d4edda"
                color = "#155724"
            elif status == "warning":
                bg_color = "#fff3cd"
                color = "#856404"
            else:
                bg_color = "#d1ecf1"
                color = "#0c5460"
            
            st.markdown(f"""
            <div style="
                background: {bg_color};
                padding: 15px;
                border-radius: 10px;
                text-align: center;
                margin: 5px 0;
            ">
                <div style="font-size: 0.9em; color: {color};">{label}</div>
                <div style="font-size: 1.8em; font-weight: 700; color: {color};">{value}</div>
            </div>
            """, unsafe_allow_html=True)
    
    st.markdown('</div>', unsafe_allow_html=True)

with col2:
    st.markdown('<div class="chart-container">', unsafe_allow_html=True)
    st.markdown('<div class="chart-title"> Live Activity Feed</div>', unsafe_allow_html=True)
    
    if st.session_state.recent_activity:
        for activity in st.session_state.recent_activity:
            if activity['type'] == 'success':
                bg_color = "#d4edda"
                border_color = "#28a745"
                color = "#155724"
            elif activity['type'] == 'warning':
                bg_color = "#fff3cd"
                border_color = "#ffc107"
                color = "#856404"
            else:
                bg_color = "#d1ecf1"
                border_color = "#17a2b8"
                color = "#0c5460"
            
            st.markdown(f"""
            <div style="
                background: {bg_color};
                border-left: 4px solid {border_color};
                padding: 10px 15px;
                margin: 5px 0;
                border-radius: 5px;
                color: {color};
                display: flex;
                justify-content: space-between;
                align-items: center;
            ">
                <span>{activity['text']}</span>
                <span style="font-size: 0.85em; opacity: 0.8;">{activity['time']}</span>
            </div>
            """, unsafe_allow_html=True)
    else:
        st.info("No recent activity")
    
    st.markdown('</div>', unsafe_allow_html=True)

